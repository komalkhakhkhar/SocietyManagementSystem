<Window x:Class="SocietyManagementSystem.TenantWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Tenant Management" Height="640" Width="1040" WindowStartupLocation="CenterScreen" ResizeMode="CanResize" WindowStyle="SingleBorderWindow" FontFamily="Segoe UI" Loaded="Window_Loaded">
    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#FFEDF5FF" Offset="0"/>
                <GradientStop Color="#FFEEF9F2" Offset="0.45"/>
                <GradientStop Color="#FFF7ECFF" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Margin="16" Padding="20" Background="#FFFFFFFF" CornerRadius="28" BorderBrush="#E4E9F2" BorderThickness="1" Effect="{DynamicResource WindowShadow}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Tenant Management" FontSize="28" FontWeight="Bold" Foreground="#1F3147" />
                    <TextBlock Text="Manage society tenant details, contacts and important dates." FontSize="14" Foreground="#62768D" Margin="0,6,0,0" />
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="Rents" Width="80" Height="38" Margin="0,0,8,0" Click="BtnRents_Click" Background="#4CAF50" Foreground="White" BorderBrush="Transparent" VerticalAlignment="Center" ToolTip="Manage rent collection and payments" />
                    <Button Content="Maintenance" Width="110" Height="38" Margin="0,0,8,0" Click="BtnMaintenance_Click" Background="#FF9800" Foreground="White" BorderBrush="Transparent" VerticalAlignment="Center" ToolTip="Handle maintenance requests" />
                    <Button Content="Notices" Width="80" Height="38" Margin="0,0,8,0" Click="BtnNotices_Click" Background="#9C27B0" Foreground="White" BorderBrush="Transparent" VerticalAlignment="Center" ToolTip="Post and manage announcements" />
                    <Button Content="Logout" Width="80" Height="38" Click="BtnLogout_Click" Background="#EF5B5B" Foreground="White" BorderBrush="Transparent" VerticalAlignment="Center" ToolTip="Logout and return to login" />
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Margin="16,0,16,16" Padding="20" Background="#FFFFFFFF" CornerRadius="24" BorderBrush="#E4E9F2" BorderThickness="1" Effect="{DynamicResource WindowShadow}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Margin="8" Padding="16" Background="#F8F9FA" CornerRadius="12" BorderBrush="#E9ECEF" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Total Tenants" FontSize="14" Foreground="#6C757D" />
                        <TextBlock x:Name="txtTotalTenants" Text="0" FontSize="24" FontWeight="Bold" Foreground="#495057" />
                    </StackPanel>
                </Border>
                <Border Grid.Column="1" Margin="8" Padding="16" Background="#F8F9FA" CornerRadius="12" BorderBrush="#E9ECEF" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Active Rents" FontSize="14" Foreground="#6C757D" />
                        <TextBlock x:Name="txtActiveRents" Text="0" FontSize="24" FontWeight="Bold" Foreground="#495057" />
                    </StackPanel>
                </Border>
                <Border Grid.Column="2" Margin="8" Padding="16" Background="#F8F9FA" CornerRadius="12" BorderBrush="#E9ECEF" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Pending Maintenance" FontSize="14" Foreground="#6C757D" />
                        <TextBlock x:Name="txtPendingMaintenance" Text="0" FontSize="24" FontWeight="Bold" Foreground="#495057" />
                    </StackPanel>
                </Border>
                <Border Grid.Column="3" Margin="8" Padding="16" Background="#F8F9FA" CornerRadius="12" BorderBrush="#E9ECEF" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Active Notices" FontSize="14" Foreground="#6C757D" />
                        <TextBlock x:Name="txtActiveNotices" Text="0" FontSize="24" FontWeight="Bold" Foreground="#495057" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Row="2" Margin="16,0,16,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="360" />
                <ColumnDefinition Width="18" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#FFFFFFFF" CornerRadius="24" Padding="18" BorderBrush="#E4E9F2" BorderThickness="1" Effect="{DynamicResource WindowShadow}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="Tenant Details" FontSize="18" FontWeight="SemiBold" Foreground="#223350" Margin="0,0,0,14" />
                        <StackPanel Margin="0,0,0,10">
                            <TextBlock Text="Title" FontSize="12" Foreground="#6F7D94" Margin="0,0,0,4" />
                            <ComboBox x:Name="cmbTitle" Width="Auto" Height="38" ItemsSource="{Binding Titles}" SelectedItem="{Binding SelectedTitle}" />
                        </StackPanel>
                        <StackPanel Margin="0,0,0,10">
                            <TextBlock Text="First Name" FontSize="12" Foreground="#6F7D94" Margin="0,0,0,4" />
                            <TextBox x:Name="txtFirstName" Height="38" />
                        </StackPanel>
                        <StackPanel Margin="0,0,0,10">
                            <TextBlock Text="Middle Name" FontSize="12" Foreground="#6F7D94" Margin="0,0,0,4" />
                            <TextBox x:Name="txtMiddleName" Height="38" />
                        </StackPanel>
                        <StackPanel Margin="0,0,0,10">
                            <TextBlock Text="Last Name" FontSize="12" Foreground="#6F7D94" Margin="0,0,0,4" />
                            <TextBox x:Name="txtLastName" Height="38" />
                        </StackPanel>
                        <StackPanel Margin="0,0,0,10">
                            <TextBlock Text="Gender" FontSize="12" Foreground="#6F7D94" Margin="0,0,0,4" />
                            <ComboBox x:Name="cmbGender" Height="38" ItemsSource="{Binding Genders}" SelectedItem="{Binding SelectedGender}" />
                        </StackPanel>
                        <StackPanel Margin="0,0,0,10">
                            <TextBlock Text="Email" FontSize="12" Foreground="#6F7D94" Margin="0,0,0,4" />
                            <TextBox x:Name="txtEmail" Height="38" />
                        </StackPanel>
                        <StackPanel Margin="0,0,0,10">
                            <TextBlock Text="Phone" FontSize="12" Foreground="#6F7D94" Margin="0,0,0,4" />
                            <TextBox x:Name="txtPhone" Height="38" />
                        </StackPanel>
                        <StackPanel Margin="0,0,0,10">
                            <TextBlock Text="Unit Number" FontSize="12" Foreground="#6F7D94" Margin="0,0,0,4" />
                            <TextBox x:Name="txtUnitNumber" Height="38" />
                        </StackPanel>
                        <StackPanel Margin="0,0,0,10">
                            <TextBlock Text="Status" FontSize="12" Foreground="#6F7D94" Margin="0,0,0,4" />
                            <ComboBox x:Name="cmbStatus" Height="38" ItemsSource="{Binding Statuses}" SelectedItem="{Binding SelectedStatus}" />
                        </StackPanel>
                        <StackPanel Margin="0,0,0,10">
                            <TextBlock Text="Date of Birth" FontSize="12" Foreground="#6F7D94" Margin="0,0,0,4" />
                            <DatePicker x:Name="dpDOB" Height="38" />
                        </StackPanel>
                        <StackPanel Margin="0,0,0,10">
                            <TextBlock Text="Anniversary" FontSize="12" Foreground="#6F7D94" Margin="0,0,0,4" />
                            <DatePicker x:Name="dpAnniversary" Height="38" />
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <Border Grid.Column="2" Background="#FFFFFFFF" CornerRadius="24" Padding="18" BorderBrush="#E4E9F2" BorderThickness="1" Effect="{DynamicResource WindowShadow}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,12">
                        <TextBox x:Name="txtSearch" Width="200" Height="38" Margin="0,0,8,0" />
                        <Button Content="Search" Width="80" Height="38" Margin="0,0,16,0" Click="BtnSearch_Click" Background="#4CAF50" Foreground="White" BorderBrush="Transparent" />
                        <Button Content="Add" Width="96" Height="38" Margin="0,0,8,0" Click="BtnAdd_Click" Background="#6C63FF" Foreground="White" BorderBrush="Transparent" />
                        <Button Content="Edit" Width="96" Height="38" Margin="0,0,8,0" Click="BtnEdit_Click" Background="#FFB133" Foreground="White" BorderBrush="Transparent" />
                        <Button Content="Delete" Width="96" Height="38" Click="BtnDelete_Click" Background="#EF5B5B" Foreground="White" BorderBrush="Transparent" />
                    </StackPanel>

                    <DataGrid x:Name="dgTenants" Grid.Row="1" AutoGenerateColumns="False" CanUserAddRows="False" HeadersVisibility="Column" SelectionMode="Single" SelectionChanged="DgTenants_SelectionChanged">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Title" Binding="{Binding Title}" Width="60"/>
                            <DataGridTextColumn Header="First Name" Binding="{Binding FirstName}" Width="100"/>
                            <DataGridTextColumn Header="Last Name" Binding="{Binding LastName}" Width="100"/>
                            <DataGridTextColumn Header="Unit" Binding="{Binding UnitNumber}" Width="80"/>
                            <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="80"/>
                            <DataGridTextColumn Header="Gender" Binding="{Binding Gender}" Width="70"/>
                            <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="150"/>
                            <DataGridTextColumn Header="Phone" Binding="{Binding Phone}" Width="120"/>
                            <DataGridTextColumn Header="DOB" Binding="{Binding DateOfBirth, StringFormat=d}" Width="90"/>
                            <DataGridTextColumn Header="Anniversary" Binding="{Binding Anniversary, StringFormat=d}" Width="100"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>
        <Grid.Resources>
            <DropShadowEffect x:Key="WindowShadow" BlurRadius="24" ShadowDepth="0" Color="#4A5A7A" Opacity="0.14" />
        </Grid.Resources>
    </Grid>
</Window>
