<Window x:Class="SocietyManagementSystem.TenantWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SocietyManagementSystem"
        mc:Ignorable="d"
        Title="Tenant Management" Height="520" Width="820" WindowStartupLocation="CenterScreen" ResizeMode="CanResize" WindowStyle="SingleBorderWindow">
      <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#FF77D6FF" Offset="0.0"/>
                <GradientStop Color="#FFB7F8DB" Offset="0.45"/>
                <GradientStop Color="#FFF9D1FF" Offset="1.0"/>
            </LinearGradientBrush>
        </Grid.Background>

        <Grid Grid.Row="1" Margin="16,16,16,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="360" />
                <ColumnDefinition Width="18" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#FFFFFFFF" CornerRadius="24" Padding="18" BorderBrush="#E4E9F2" BorderThickness="1" Effect="{DynamicResource WindowShadow}">
                <StackPanel>
                    <TextBlock Text="Tenant Details" FontSize="18" FontWeight="SemiBold" Foreground="#223350" Margin="0,0,0,14" />
                    <StackPanel Margin="0,0,0,10">
                        <TextBlock Text="Title" FontSize="12" Foreground="#6F7D94" Margin="0,0,0,4" />
                        <ComboBox x:Name="cmbTitle" Width="Auto" Height="25" ItemsSource="{Binding Titles}" SelectedItem="{Binding SelectedTitle}" />
                    </StackPanel>
                    <StackPanel Margin="0,0,0,10">
                        <TextBlock Text="First Name" FontSize="12" Foreground="#6F7D94" Margin="0,0,0,4" />
                        <TextBox x:Name="txtFirstName" Height="25" />
                    </StackPanel>
                    <StackPanel Margin="0,0,0,10">
                        <TextBlock Text="Middle Name" FontSize="12" Foreground="#6F7D94" Margin="0,0,0,4" />
                        <TextBox x:Name="txtMiddleName" Height="25" />
                    </StackPanel>
                    <StackPanel Margin="0,0,0,10">
                        <TextBlock Text="Last Name" FontSize="12" Foreground="#6F7D94" Margin="0,0,0,4" />
                        <TextBox x:Name="txtLastName" Height="25" />
                    </StackPanel>
                    <StackPanel Margin="0,0,0,10">
                        <TextBlock Text="Gender" FontSize="12" Foreground="#6F7D94" Margin="0,0,0,4" />
                        <ComboBox x:Name="cmbGender" Height="25" ItemsSource="{Binding Genders}" SelectedItem="{Binding SelectedGender}" />
                    </StackPanel>
                    <StackPanel Margin="0,0,0,10">
                        <TextBlock Text="Email" FontSize="12" Foreground="#6F7D94" Margin="0,0,0,4" />
                        <TextBox x:Name="txtEmail" Height="25" />
                    </StackPanel>
                    <StackPanel Margin="0,0,0,10">
                        <TextBlock Text="Phone" FontSize="12" Foreground="#6F7D94" Margin="0,0,0,4" />
                        <TextBox x:Name="txtPhone" Height="25" />
                    </StackPanel>
                    <StackPanel Margin="0,0,0,10">
                        <TextBlock Text="Date of Birth" FontSize="12" Foreground="#6F7D94" Margin="0,0,0,4" />
                        <DatePicker x:Name="dpDOB" Height="25" />
                    </StackPanel>
                    <StackPanel Margin="0,0,0,10">
                        <TextBlock Text="Anniversary" FontSize="12" Foreground="#6F7D94" Margin="0,0,0,4" />
                        <DatePicker x:Name="dpAnniversary" Height="25" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Background="#FFFFFFFF" CornerRadius="24" Padding="18" BorderBrush="#E4E9F2" BorderThickness="1" Effect="{DynamicResource WindowShadow}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,12">
                        <Button Content="Add" Width="96" Height="38" Margin="0,0,8,0" Click="BtnAdd_Click" Background="#6C63FF" Foreground="White" BorderBrush="Transparent" />
                        <Button Content="Edit" Width="96" Height="38" Margin="0,0,8,0" Click="BtnEdit_Click" Background="#FFB133" Foreground="White" BorderBrush="Transparent" />
                        <Button Content="Delete" Width="96" Height="38" Click="BtnDelete_Click" Background="#EF5B5B" Foreground="White" BorderBrush="Transparent" />
                    </StackPanel>

                    <DataGrid x:Name="dgTenants" Grid.Row="1" AutoGenerateColumns="False" CanUserAddRows="False" HeadersVisibility="Column" SelectionMode="Single" SelectionChanged="DgTenants_SelectionChanged">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Title" Binding="{Binding Title}" Width="100"/>
                            <DataGridTextColumn Header="First Name" Binding="{Binding FirstName}" Width="140"/>
                            <DataGridTextColumn Header="Last Name" Binding="{Binding LastName}" Width="140"/>
                            <DataGridTextColumn Header="Gender" Binding="{Binding Gender}" Width="90"/>
                            <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="180"/>
                            <DataGridTextColumn Header="Phone" Binding="{Binding Phone}" Width="120"/>
                            <DataGridTextColumn Header="DOB" Binding="{Binding DateOfBirth, StringFormat=d}" Width="110"/>
                            <DataGridTextColumn Header="Anniversary" Binding="{Binding Anniversary, StringFormat=d}" Width="120"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>
        <Grid.Resources>
            <DropShadowEffect x:Key="WindowShadow" BlurRadius="24" ShadowDepth="0" Color="#4A5A7A" Opacity="0.14" />
        </Grid.Resources>
    </Grid>
</Window>
