<Window x:Class="SocietyManagementSystem.Dashboard"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Dashboard - Society Management System" Height="650" Width="1200" WindowStartupLocation="CenterScreen" ResizeMode="CanResize" WindowStyle="SingleBorderWindow" FontFamily="Segoe UI" Loaded="Window_Loaded">
    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#FFEDF5FF" Offset="0"/>
                <GradientStop Color="#FFEEF9F2" Offset="0.45"/>
                <GradientStop Color="#FFF7ECFF" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Margin="16" Padding="20" Background="#FFFFFFFF" CornerRadius="28" BorderBrush="#E4E9F2" BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Dashboard" FontSize="28" FontWeight="Bold" Foreground="#1F3147" />
                    <TextBlock Text="Welcome back! Here's your society overview." FontSize="14" Foreground="#62768D" Margin="0,6,0,0" />
                </StackPanel>
                <Button Grid.Column="1" Content="Logout" Click="BtnLogout_Click" Width="90" Height="40" Background="#EF5B5B" Foreground="White" BorderBrush="Transparent" VerticalAlignment="Center" ToolTip="Logout and return to login" FontWeight="SemiBold" />
            </Grid>
        </Border>

        <!-- Statistics Cards -->
        <Border Grid.Row="1" Margin="16,0,16,16" Padding="20" Background="#FFFFFFFF" CornerRadius="24" BorderBrush="#E4E9F2" BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <!-- Total Tenants -->
                <Border Grid.Column="0" Margin="8" Padding="20" Background="#F0F4FF" CornerRadius="16" BorderBrush="#E4E9F2" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Total Tenants" FontSize="13" Foreground="#6C757D" FontWeight="SemiBold" />
                        <TextBlock x:Name="txtTotalTenants" Text="0" FontSize="32" FontWeight="Bold" Foreground="#6C63FF" Margin="0,8,0,0" />
                    </StackPanel>
                </Border>

                <!-- Active Rents -->
                <Border Grid.Column="1" Margin="8" Padding="20" Background="#F0FFF4" CornerRadius="16" BorderBrush="#E4E9F2" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Active Rents" FontSize="13" Foreground="#6C757D" FontWeight="SemiBold" />
                        <TextBlock x:Name="txtActiveRents" Text="0" FontSize="32" FontWeight="Bold" Foreground="#4CAF50" Margin="0,8,0,0" />
                    </StackPanel>
                </Border>

                <!-- Pending Maintenance -->
                <Border Grid.Column="2" Margin="8" Padding="20" Background="#FFF8F0" CornerRadius="16" BorderBrush="#E4E9F2" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Pending Maintenance" FontSize="13" Foreground="#6C757D" FontWeight="SemiBold" />
                        <TextBlock x:Name="txtPendingMaintenance" Text="0" FontSize="32" FontWeight="Bold" Foreground="#FF9800" Margin="0,8,0,0" />
                    </StackPanel>
                </Border>

                <!-- Active Notices -->
                <Border Grid.Column="3" Margin="8" Padding="20" Background="#F7F0FF" CornerRadius="16" BorderBrush="#E4E9F2" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Active Notices" FontSize="13" Foreground="#6C757D" FontWeight="SemiBold" />
                        <TextBlock x:Name="txtActiveNotices" Text="0" FontSize="32" FontWeight="Bold" Foreground="#9C27B0" Margin="0,8,0,0" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Main Content Area -->
        <Border Grid.Row="2" Margin="16,0,16,16" Padding="20" Background="#FFFFFFFF" CornerRadius="24" BorderBrush="#E4E9F2" BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Tenants Card -->
                <Border Grid.Column="0" Grid.Row="0" Margin="8" Padding="20" Background="#F0F4FF" CornerRadius="16" BorderBrush="#E4E9F2" BorderThickness="1" Cursor="Hand" MouseDown="Card_MouseDown">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Manage Tenants" FontSize="18" FontWeight="Bold" Foreground="#1F3147" />
                            <TextBlock Text="View and manage all tenant information" FontSize="12" Foreground="#62768D" Margin="0,6,0,0" />
                        </StackPanel>
                        <TextBlock Grid.Column="1" FontFamily="Segoe MDL2 Assets" Text="&#xE77B;" FontSize="40" Foreground="#6C63FF" VerticalAlignment="Center" HorizontalAlignment="Right" />
                    </Grid>
                </Border>

                <!-- Rents Card -->
                <Border Grid.Column="1" Grid.Row="0" Margin="8" Padding="20" Background="#F0FFF4" CornerRadius="16" BorderBrush="#E4E9F2" BorderThickness="1" Cursor="Hand" MouseDown="Card_MouseDown">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Manage Rents" FontSize="18" FontWeight="Bold" Foreground="#1F3147" />
                            <TextBlock Text="Track and manage rent payments" FontSize="12" Foreground="#62768D" Margin="0,6,0,0" />
                        </StackPanel>
                        <TextBlock Grid.Column="1" FontFamily="Segoe MDL2 Assets" Text="&#xE721;" FontSize="40" Foreground="#4CAF50" VerticalAlignment="Center" HorizontalAlignment="Right" />
                    </Grid>
                </Border>

                <!-- Maintenance Card -->
                <Border Grid.Column="0" Grid.Row="1" Margin="8" Padding="20" Background="#FFF8F0" CornerRadius="16" BorderBrush="#E4E9F2" BorderThickness="1" Cursor="Hand" MouseDown="Card_MouseDown">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Maintenance Requests" FontSize="18" FontWeight="Bold" Foreground="#1F3147" />
                            <TextBlock Text="Handle maintenance and repairs" FontSize="12" Foreground="#62768D" Margin="0,6,0,0" />
                        </StackPanel>
                        <TextBlock Grid.Column="1" FontFamily="Segoe MDL2 Assets" Text="&#xE713;" FontSize="40" Foreground="#FF9800" VerticalAlignment="Center" HorizontalAlignment="Right" />
                    </Grid>
                </Border>

                <!-- Notices Card -->
                <Border Grid.Column="1" Grid.Row="1" Margin="8" Padding="20" Background="#F7F0FF" CornerRadius="16" BorderBrush="#E4E9F2" BorderThickness="1" Cursor="Hand" MouseDown="Card_MouseDown">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Announcements" FontSize="18" FontWeight="Bold" Foreground="#1F3147" />
                            <TextBlock Text="Post and manage announcements" FontSize="12" Foreground="#62768D" Margin="0,6,0,0" />
                        </StackPanel>
                        <TextBlock Grid.Column="1" FontFamily="Segoe MDL2 Assets" Text="&#xE7BA;" FontSize="40" Foreground="#9C27B0" VerticalAlignment="Center" HorizontalAlignment="Right" />
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <Grid.Resources>
            <DropShadowEffect x:Key="WindowShadow" BlurRadius="24" ShadowDepth="0" Color="#4A5A7A" Opacity="0.14" />
        </Grid.Resources>
    </Grid>
</Window>
