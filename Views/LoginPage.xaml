<Page x:Class="WPF.Views.LoginPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      Title="LoginPage" Height="300" Width="400">
    <Grid>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock Text="Login" FontSize="24" HorizontalAlignment="Center" Margin="0,0,0,20"/>
            <TextBlock Text="Username:"/>
            <TextBox x:Name="UsernameTextBox" Width="200" Margin="0,0,0,10"/>
            <TextBlock Text="Password:"/>
            <PasswordBox x:Name="PasswordBox" Width="200" Margin="0,0,0,20"/>
            <Button x:Name="LoginButton" Content="Login" Width="100" Click="LoginButton_Click"/>
            <Button x:Name="GoToSignupButton" Content="Go to Signup" Width="100" Margin="0,10,0,0" Click="GoToSignupButton_Click"/>
        </StackPanel>
    </Grid>
</Page>