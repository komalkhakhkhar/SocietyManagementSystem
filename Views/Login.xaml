<Window x:Class="SocietyManagementSystem.Login"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SocietyManagementSystem"
        mc:Ignorable="d"
        Title="Login" Height="520" Width="820" WindowStartupLocation="CenterScreen" ResizeMode="CanResize" WindowStyle="SingleBorderWindow">
    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#FF77D6FF" Offset="0.0"/>
                <GradientStop Color="#FFB7F8DB" Offset="0.45"/>
                <GradientStop Color="#FFF9D1FF" Offset="1.0"/>
            </LinearGradientBrush>
        </Grid.Background>

        <Border Width="440" Padding="36" Background="#FAFCFF" CornerRadius="36" HorizontalAlignment="Center" VerticalAlignment="Center" Effect="{DynamicResource DropShadowEffect}">
            <StackPanel>
                <Image Source="rr_logo.png" Width="58" Height="58" HorizontalAlignment="Center" Margin="0,0,0,14" />
                <TextBlock Text="Society Management" FontSize="28" FontWeight="Bold" Foreground="#1F2C3B" HorizontalAlignment="Center" TextAlignment="Center" />
                <TextBlock Text="Sign in to continue to your society dashboard" FontSize="14" Foreground="#5B6B82" TextAlignment="Center" Margin="0,8,0,26" TextWrapping="Wrap" />

                <TextBlock Text="Society name" FontSize="12" Foreground="#6B7B90" Margin="4,0,0,6" />
                <Border CornerRadius="14" Background="White" BorderBrush="#D9E2F0" BorderThickness="1" Margin="0,0,0,12" Height="48">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="42" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE71D;" FontSize="18" Foreground="#8D99A8" VerticalAlignment="Center" HorizontalAlignment="Center" />
                        <TextBox x:Name="txtSocietyName" Grid.Column="1" BorderThickness="0" Background="Transparent" Foreground="#222" FontSize="14" VerticalContentAlignment="Center" Padding="6,0" />
                    </Grid>
                </Border>

                <TextBlock Text="Username" FontSize="12" Foreground="#6B7B90" Margin="4,0,0,6" />
                <Border CornerRadius="14" Background="White" BorderBrush="#D9E2F0" BorderThickness="1" Margin="0,0,0,12" Height="48">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="42" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE77B;" FontSize="18" Foreground="#8D99A8" VerticalAlignment="Center" HorizontalAlignment="Center" />
                        <TextBox x:Name="txtUsername" Grid.Column="1" BorderThickness="0" Background="Transparent" Foreground="#222" FontSize="14" VerticalContentAlignment="Center" Padding="6,0" />
                    </Grid>
                </Border>

                <TextBlock Text="Password" FontSize="12" Foreground="#6B7B90" Margin="4,0,0,6" />
                <Border CornerRadius="14" Background="White" BorderBrush="#D9E2F0" BorderThickness="1" Margin="0,0,0,18" Height="48">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="42" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE72E;" FontSize="18" Foreground="#8D99A8" VerticalAlignment="Center" HorizontalAlignment="Center" />
                        <PasswordBox x:Name="txtPassword" Grid.Column="1" BorderThickness="0" Background="Transparent" Foreground="#222" FontSize="14" VerticalContentAlignment="Center" Padding="6,0" />
                    </Grid>
                </Border>

                <TextBlock Text="forgot password?" Foreground="#62748D" FontSize="12" HorizontalAlignment="Right" Margin="0,0,0,22" Cursor="Hand" />

                <Button Content="Login" Click="btnLogin_Click" Height="48" Margin="0,0,0,12" FontSize="16" FontWeight="SemiBold" Foreground="White" BorderBrush="Transparent" Cursor="Hand">
                    <Button.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#7F5BFF" Offset="0.0" />
                            <GradientStop Color="#3DA6FF" Offset="1.0" />
                        </LinearGradientBrush>
                    </Button.Background>
                    <Button.Effect>
                        <DropShadowEffect Color="#6A7BFF" BlurRadius="14" ShadowDepth="0" Opacity="0.25" />
                    </Button.Effect>
                </Button>

                <Button x:Name="btnSignup" Content="Sign up" Click="btnSignup_Click" Height="48" FontSize="16" FontWeight="SemiBold" Foreground="#2E3E56" Background="#E9EFF9" BorderBrush="Transparent" Cursor="Hand" />

                <TextBlock x:Name="lblMessage" Foreground="#E53935" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,18,0,0" TextWrapping="Wrap" />
            </StackPanel>
        </Border>

        <Grid.Resources>
            <DropShadowEffect x:Key="DropShadowEffect" BlurRadius="32" ShadowDepth="0" Color="#40506B" Opacity="0.16" />
        </Grid.Resources>
    </Grid>
</Window>
