<Window x:Class="SocietyManagementSystem.MaintenanceWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Maintenance Requests" Height="640" Width="1040" WindowStartupLocation="CenterScreen" ResizeMode="CanResize" WindowStyle="SingleBorderWindow">
    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#FFEDF5FF" Offset="0"/>
                <GradientStop Color="#FFEEF9F2" Offset="0.45"/>
                <GradientStop Color="#FFF7ECFF" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Margin="16" Padding="20" Background="#FFFFFFFF" CornerRadius="28" BorderBrush="#E4E9F2" BorderThickness="1" Effect="{DynamicResource WindowShadow}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Maintenance Requests" FontSize="28" FontWeight="Bold" Foreground="#1F3147" />
                    <TextBlock Text="Manage maintenance and service requests." FontSize="14" Foreground="#62768D" Margin="0,6,0,0" />
                </StackPanel>
                <Button Grid.Column="1" Content="Back" Width="80" Height="38" Click="BtnBack_Click" Background="#EF5B5B" Foreground="White" BorderBrush="Transparent" VerticalAlignment="Center" />
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="16,0,16,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="360" />
                <ColumnDefinition Width="18" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#FFFFFFFF" CornerRadius="24" Padding="18" BorderBrush="#E4E9F2" BorderThickness="1" Effect="{DynamicResource WindowShadow}">
                <StackPanel>
                    <TextBlock Text="Request Details" FontSize="18" FontWeight="SemiBold" Foreground="#223350" Margin="0,0,0,14" />
                    <StackPanel Margin="0,0,0,10">
                        <TextBlock Text="Tenant" FontSize="12" Foreground="#6F7D94" Margin="0,0,0,4" />
                        <ComboBox x:Name="cmbTenant" Height="38" DisplayMemberPath="FirstName" SelectedValuePath="Id" />
                    </StackPanel>
                    <StackPanel Margin="0,0,0,10">
                        <TextBlock Text="Title" FontSize="12" Foreground="#6F7D94" Margin="0,0,0,4" />
                        <TextBox x:Name="txtTitle" Height="38" />
                    </StackPanel>
                    <StackPanel Margin="0,0,0,10">
                        <TextBlock Text="Description" FontSize="12" Foreground="#6F7D94" Margin="0,0,0,4" />
                        <TextBox x:Name="txtDescription" Height="80" TextWrapping="Wrap" AcceptsReturn="True" />
                    </StackPanel>
                    <StackPanel Margin="0,0,0,10">
                        <TextBlock Text="Category" FontSize="12" Foreground="#6F7D94" Margin="0,0,0,4" />
                        <ComboBox x:Name="cmbCategory" Height="38" ItemsSource="{Binding Categories}" />
                    </StackPanel>
                    <StackPanel Margin="0,0,0,10">
                        <TextBlock Text="Priority" FontSize="12" Foreground="#6F7D94" Margin="0,0,0,4" />
                        <ComboBox x:Name="cmbPriority" Height="38" ItemsSource="{Binding Priorities}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Background="#FFFFFFFF" CornerRadius="24" Padding="18" BorderBrush="#E4E9F2" BorderThickness="1" Effect="{DynamicResource WindowShadow}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,12">
                        <Button Content="Add Request" Width="110" Height="38" Margin="0,0,8,0" Click="BtnAddRequest_Click" Background="#6C63FF" Foreground="White" BorderBrush="Transparent" />
                        <Button Content="Update Status" Width="120" Height="38" Margin="0,0,8,0" Click="BtnUpdateStatus_Click" Background="#FFB133" Foreground="White" BorderBrush="Transparent" />
                        <Button Content="Delete" Width="80" Height="38" Click="BtnDeleteRequest_Click" Background="#EF5B5B" Foreground="White" BorderBrush="Transparent" />
                    </StackPanel>

                    <DataGrid x:Name="dgRequests" Grid.Row="1" AutoGenerateColumns="False" CanUserAddRows="False" HeadersVisibility="Column" SelectionMode="Single" SelectionChanged="DgRequests_SelectionChanged">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Tenant" Binding="{Binding TenantName}" Width="120"/>
                            <DataGridTextColumn Header="Title" Binding="{Binding Title}" Width="150"/>
                            <DataGridTextColumn Header="Category" Binding="{Binding Category}" Width="100"/>
                            <DataGridTextColumn Header="Priority" Binding="{Binding Priority}" Width="80"/>
                            <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="80"/>
                            <DataGridTextColumn Header="Created" Binding="{Binding CreatedDate, StringFormat=d}" Width="100"/>
                            <DataGridTextColumn Header="Resolved" Binding="{Binding ResolvedDate, StringFormat=d}" Width="100"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>
        <Grid.Resources>
            <DropShadowEffect x:Key="WindowShadow" BlurRadius="24" ShadowDepth="0" Color="#4A5A7A" Opacity="0.14" />
        </Grid.Resources>
    </Grid>
</Window>