<Window x:Class="SocietyManagementSystem.Signup"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SocietyManagementSystem"
        mc:Ignorable="d"
        Title="Signup" Height="450" Width="800" WindowStartupLocation="CenterScreen" ResizeMode="CanResize" WindowStyle="SingleBorderWindow">
    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#FF6DD5FA" Offset="0.0"/>
                <GradientStop Color="#FFB7F8DB" Offset="0.5"/>
                <GradientStop Color="#FFF9D1FF" Offset="1.0"/>
            </LinearGradientBrush>
        </Grid.Background>

        <!-- Centered Card -->
        <Border CornerRadius="40" Background="#F8F8F8CC" Padding="40" Width="350" Height="450" HorizontalAlignment="Center" VerticalAlignment="Center" Effect="{DynamicResource DropShadowEffect}">
            <StackPanel>
                <Image Source="rr_logo.png" Width="64" Height="64" HorizontalAlignment="Center" Margin="0,0,0,10" />
                <TextBlock Text="SocietyManagementSystem" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,20" />

                <!-- Society Name Field -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,10">
                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE71D;" FontSize="18" VerticalAlignment="Center" Margin="0,0,8,0" />
                    <TextBox x:Name="txtSocietyName" Width="220" Height="32" VerticalContentAlignment="Center" Margin="0" Padding="0,0,0,0" BorderThickness="0,0,0,1" BorderBrush="#AAA" Background="Transparent"/>
                </StackPanel>

                <!-- Username Field -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,10">
                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE77B;" FontSize="18" VerticalAlignment="Center" Margin="0,0,8,0" />
                    <TextBox x:Name="txtUsername" Width="220" Height="32" VerticalContentAlignment="Center" Margin="0" Padding="0,0,0,0" BorderThickness="0,0,0,1" BorderBrush="#AAA" Background="Transparent"/>
                </StackPanel>

                <!-- Email Field -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,10">
                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE715;" FontSize="18" VerticalAlignment="Center" Margin="0,0,8,0" />
                    <TextBox x:Name="txtEmail" Width="220" Height="32" VerticalContentAlignment="Center" Margin="0" Padding="0,0,0,0" BorderThickness="0,0,0,1" BorderBrush="#AAA" Background="Transparent"/>
                </StackPanel>

                <!-- Password Field -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,10">
                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE72E;" FontSize="18" VerticalAlignment="Center" Margin="0,0,8,0" />
                    <PasswordBox x:Name="txtPassword" Width="220" Height="32" VerticalContentAlignment="Center" Margin="0" Padding="0,0,0,0" BorderThickness="0,0,0,1" BorderBrush="#AAA" Background="Transparent"/>
                </StackPanel>

                <Button Content="signup" Click="btnSignup_Click" Height="38" Margin="0,10,0,0" FontSize="16" FontWeight="Bold" Foreground="White">
                    <Button.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#FFB224EF" Offset="0.0"/>
                            <GradientStop Color="#FF44C5F6" Offset="1.0"/>
                        </LinearGradientBrush>
                    </Button.Background>
                </Button>
                <TextBlock x:Name="lblMessage" Foreground="Red" HorizontalAlignment="Center" Margin="0,10,0,0" />
            </StackPanel>
        </Border>
        <!-- Optional: Drop shadow effect resource -->
        <Grid.Resources>
            <DropShadowEffect x:Key="DropShadowEffect" BlurRadius="20" ShadowDepth="0" Color="#888" Opacity="0.3" />
        </Grid.Resources>
    </Grid>
</Window>