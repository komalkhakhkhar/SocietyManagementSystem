<Window x:Class="SocietyManagementSystem.Signup"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SocietyManagementSystem"
        mc:Ignorable="d"
        Title="Sign Up" Height="520" Width="820" WindowStartupLocation="CenterScreen" ResizeMode="CanResize" WindowStyle="SingleBorderWindow">
      <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#FF77D6FF" Offset="0.0"/>
                <GradientStop Color="#FFB7F8DB" Offset="0.45"/>
                <GradientStop Color="#FFF9D1FF" Offset="1.0"/>
            </LinearGradientBrush>
        </Grid.Background>

        <!-- Centered Card -->
       <Border Width="440" Padding="36" Background="#FAFCFF" CornerRadius="36" HorizontalAlignment="Center" VerticalAlignment="Center" Effect="{DynamicResource DropShadowEffect}">
            <StackPanel>
                <Image Source="rr_logo.png" Width="64" Height="64" HorizontalAlignment="Center" Margin="0,0,0,10" />
                <TextBlock Text="Society Management" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,20" />

                <!-- Society Name Field -->
                <TextBlock Text="Society name" FontSize="12" Foreground="#6B7B90" Margin="4,0,0,6" />
                <Border CornerRadius="14" Background="White" BorderBrush="#D9E2F0" BorderThickness="1" Margin="0,0,0,12" Height="48">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="42" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE71D;" FontSize="18" Foreground="#8D99A8" VerticalAlignment="Center" HorizontalAlignment="Center" />
                        <TextBox x:Name="txtSocietyName" Grid.Column="1" BorderThickness="0" Background="Transparent" Foreground="#222" FontSize="14" VerticalContentAlignment="Center" Padding="6,0" />
                    </Grid>
                </Border>

                <!-- Username Field -->
                <TextBlock Text="Username" FontSize="12" Foreground="#6B7B90" Margin="4,0,0,6" />
                <Border CornerRadius="14" Background="White" BorderBrush="#D9E2F0" BorderThickness="1" Margin="0,0,0,12" Height="48">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="42" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE77B;" FontSize="18" Foreground="#8D99A8" VerticalAlignment="Center" HorizontalAlignment="Center" />
                        <TextBox x:Name="txtUsername" Grid.Column="1" BorderThickness="0" Background="Transparent" Foreground="#222" FontSize="14" VerticalContentAlignment="Center" Padding="6,0" />
                    </Grid>
                </Border>

                <!-- Email Field -->
                <TextBlock Text="Email" FontSize="12" Foreground="#6B7B90" Margin="4,0,0,6" />
                <Border CornerRadius="14" Background="White" BorderBrush="#D9E2F0" BorderThickness="1" Margin="0,0,0,18" Height="48">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="42" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE72E;" FontSize="18" Foreground="#8D99A8" VerticalAlignment="Center" HorizontalAlignment="Center" />
                        <TextBox x:Name="txtEmail" Grid.Column="1" BorderThickness="0" Background="Transparent" Foreground="#222" FontSize="14" VerticalContentAlignment="Center" Padding="6,0" />
                    </Grid>
                </Border>

                <!-- Password Field -->
                <TextBlock Text="Password" FontSize="12" Foreground="#6B7B90" Margin="4,0,0,6" />
                <Border CornerRadius="14" Background="White" BorderBrush="#D9E2F0" BorderThickness="1" Margin="0,0,0,18" Height="48">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="42" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE72E;" FontSize="18" Foreground="#8D99A8" VerticalAlignment="Center" HorizontalAlignment="Center" />
                        <PasswordBox x:Name="txtPassword" Grid.Column="1" BorderThickness="0" Background="Transparent" Foreground="#222" FontSize="14" VerticalContentAlignment="Center" Padding="6,0" />
                    </Grid>
                </Border>

                <Button Content="signup" Click="btnSignup_Click" Height="38" Margin="0,10,0,0" FontSize="16" FontWeight="Bold" Foreground="White">
                    <Button.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#FFB224EF" Offset="0.0"/>
                            <GradientStop Color="#FF44C5F6" Offset="1.0"/>
                        </LinearGradientBrush>
                    </Button.Background>
                </Button>
                <TextBlock x:Name="lblMessage" Foreground="Red" HorizontalAlignment="Center" Margin="0,10,0,0" />
            </StackPanel>
        </Border>
        <!-- Optional: Drop shadow effect resource -->
        <Grid.Resources>
            <DropShadowEffect x:Key="DropShadowEffect" BlurRadius="20" ShadowDepth="0" Color="#888" Opacity="0.3" />
        </Grid.Resources>
    </Grid>
</Window>